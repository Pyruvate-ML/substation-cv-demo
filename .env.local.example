# DashScope (Qwen) cloud-first config
DASHSCOPE_API_KEY=sk-xxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_OCR_MODEL=qwen-vl-ocr
DASHSCOPE_ASR_MODEL=qwen3-asr-flash
DASHSCOPE_TEXT_MODEL=qwen-turbo
DASHSCOPE_TIMEOUT_SEC=45
ALLOW_ORIGINS=https://<your-github-pages-domain>

# Optional local fallback (disabled by default)
# MLX_MODEL=mlx-community/Qwen2.5-0.5B-Instruct-4bit
# MLX_MAX_TOKENS=512
# MLX_WHISPER_MODEL=mlx-community/whisper-tiny
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b
# LOCAL_ASR_COMMAND=/absolute/path/to/transcribe.sh {audio}
# WHISPER_CPP_COMMAND=/absolute/path/to/whisper-cli
# WHISPER_MODEL_PATH=/absolute/path/to/ggml-small.bin
# LOCAL_ASR_LANGUAGE=zh
